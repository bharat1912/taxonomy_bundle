# DRAM2 Vault Configuration Template
# ----------------------------------------------------------------------
# 1. Copy this file to '.env' in the project root.
# 2. Modify the paths below to match your local storage (e.g., /media/...)
# ----------------------------------------------------------------------

# The root path for the DRAM database vault
DRAM_DB=/path/to/your/vault/databases/dram_db

# The directory for Nextflow's intermediate work files
NXF_WORK=/path/to/your/vault/nextflow_work

# Fallback path for other taxonomy databases
EXTERNAL_VAULT=/path/to/your/vault/databases
