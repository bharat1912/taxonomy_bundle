# ----------------------------------------------------------------------
# Core Project Files
# ----------------------------------------------------------------------
# Pixi environment and cache
.pixi/
pixi.lock  # <- REMOVED THIS LINE. pixi.lock MUST be committed for reproducibility!
*.egg-info
*.pyc
__pycache__/
.DS_Store # macOS system files

# Conda environment cache (used by Pixi/Conda)
.conda/

# ----------------------------------------------------------------------
# Input Data Directories (Must exist but be empty on GitHub)
# ----------------------------------------------------------------------
# Rule 1: Ignore ALL files and folders inside local_data/ (recursively)
local_data/**

# Rule 2: Exception for placeholder files needed to ensure the structure exists
!local_data/.gitkeep
!local_data/assembled_genomes/.gitkeep
!local_data/fastq_reads/.gitkeep

# ----------------------------------------------------------------------
# Output/Result Directories (Generated by Snakemake - MUST be ignored)
# ----------------------------------------------------------------------
results/
logs/
pysradb_output/
raw_reads/

# ----------------------------------------------------------------------
# External Tool Files (often large or temporary)
# ----------------------------------------------------------------------
# Files generated by GToTree, CheckM, etc., that should not be tracked
*.tmp
*.log
*.err
*.out
