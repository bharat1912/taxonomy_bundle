# =============================================================================
# TAXONOMY BUNDLE - .gitignore
# =============================================================================

# Pixi environments (large, reproducible via pixi install)
.pixi/

# Local environment config (contains machine-specific paths)
.env

# Data directories
raw_data/
local_data/
input_reads/
input_reads_old/
subsampled_reads/
renamed_reads/
data/

# Results (reproducible by running workflows)
results/
results_autocycle/
work/
hybrid_taxonomy_analysis/
high_conf_gene_results/
sra_search_output/
kmer_analysis/

# Databases and symlinks (machine-specific)
db_link/
busco_downloads/

# Sample-specific data
SRR*/

# Large files
*.tar.gz
*.tgz
*.tar.xz

# Binaries
globusconnectpersonal*/
bin/seaview/

# Logs
*.log

# Snakemake metadata
.snakemake/

# Python cache
__pycache__/
*.pyc

# Temporary files
*.tmp
null
os
pd
re

# Archive (keep locally, not on GitHub)
_archive/

# Nextflow cache and logs
.nextflow/
.nextflow.log*

# Nextflow work directory
work/

# Example/old env files
.env.example

# Old pixi backup files
pixi_*.toml
pixi_*.lock
pixi_lock*.lock

# Old/generated files
screen_output
path_check.txt
post_assembly_qc_done.flag
null
name,status,updated
ref_project
*.flag

# Test data
test_dram2/
test_mytaxa/
test_genome.fna
ecoli.fasta
Ecoli.fasta
Ecoli_fasta
Ecoli_Sample.LargeContigs.fna

# Image files
*.png
*.jpg
*.pdf
'ChatGPT Image*'

# Development/chat exports
CHATGPT_downloads/
CLAUDE/

# autocycler development scripts (keep only active ones)
autocycler_all_scripts/

# bacLIFE submodule (has its own git)
bacLIFE/

# busco symlink
busco_downloads
nextflow.config
